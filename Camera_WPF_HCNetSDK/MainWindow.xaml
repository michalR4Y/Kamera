<Window x:Name="window" x:Class="Camera_WPF_HCNetSDK.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Camera_WPF_HCNetSDK"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Title="MainWindow" Height="700" Width="1190"
        Background="Black">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="150*"/>
            <RowDefinition Height="300*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        <Image 
            x:Name="BigMainCamera" 
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Stretch"
            Margin="0,0,0,0"
            Grid.RowSpan="3" Grid.Row="1"
            MouseLeftButtonDown="Image_BigMainCameraMouseLeftButtonDown" 
            Cursor="Hand"/>
        <Grid Grid.Row="0" VerticalAlignment="Top" Height="30" Background="Blue" MouseDown="TitleBar_MouseDown">
            <TextBlock Text="Camera_WPF_HCNetSDK_Main" VerticalAlignment="Center" Margin="10,0"/>
            <Button x:Name="X" Margin = "1165,0,0,0" HorizontalAlignment="Right" Click="CloseButton_Click" Width="30" Background="Transparent" BorderThickness="0" Foreground="White">
                <Button.Style>
                    <Style TargetType="Button">
                        <!-- Domyślna ikona: Pojedynczy kwadrat (Normalny stan) -->
                        <Setter Property="Content" Value="&#xE8BB;"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- TUTAJ zmieniasz kolor tła po najechaniu -->
                                <Setter Property="Background" Value="#DCDCDC"/>
                                <!-- Opcjonalnie zmiana koloru fonta po najechaniu -->
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button x:Name="MaximizeButton" Margin = "0,0,45,0" HorizontalAlignment="Right" Click="Maximize_Click" Width="30" Background="Transparent" BorderThickness="0" Foreground="White">
                <Button.Style>
                    <Style TargetType="Button">
                        <!-- Domyślna ikona: Pojedynczy kwadrat (Normalny stan) -->
                        <Setter Property="Content" Value="&#xE922;"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Style.Triggers>
                            <!-- Zmiana ikony na dwa kwadraciki, gdy okno jest zmaksymalizowane -->
                            <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                <Setter Property="Content" Value="&#xE923;"/>
                            </DataTrigger>

                            <!-- Opcjonalnie: efekt po najechaniu myszką -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Red"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button x:Name="MinimizeButton" Margin = "0,0,85,0"  HorizontalAlignment="Right" Click="Minimize_Click" Width="30" Background="Transparent" BorderThickness="0" Foreground="White">
                <Button.Style>
                    <Style TargetType="Button">
                        <!-- Domyślna ikona: Pojedynczy kwadrat (Normalny stan) -->
                        <Setter Property="Content" Value="&#xE921;"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Style.Triggers>
                            <!-- Opcjonalnie: efekt po najechaniu myszką -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="Red"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Wiersz 1 z własnym podziałem -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid Margin="2,2,2,2" Grid.Column="0">
                <Image 
                    x:Name="LeftCameraSmall" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch"
                    MouseLeftButtonDown="Image_LeftCameraMouseLeftButtonDown" 
                    Cursor="Hand"/>
                <TextBlock 
                    x:Name="LeftCameraError"
                    Text="L Error" 
                    Height="85" 
                    FontSize="60" 
                    Foreground="Red"
                    Visibility="Collapsed"
                    VerticalAlignment="Top" 
                    Margin="55,17,125,0" 
                    RenderTransformOrigin="0.476,0.504" >
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="-20" />
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Grid>
            <Grid Margin="2,2,2,2" Grid.Column="1">
                <Image 
                    x:Name="CentralCameraSmall"
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch"
                    MouseLeftButtonDown="Image_CentralCameraMouseLeftButtonDown" 
                    Cursor="Hand"/>
                <TextBlock 
                    x:Name="CentralCameraError"
                    Text="C Error" 
                    Height="85" 
                    FontSize="60" 
                    Foreground="Red" 
                    Visibility="Collapsed"
                    VerticalAlignment="Top" 
                    Margin="55,17,125,0" 
                    RenderTransformOrigin="0.476,0.504" >
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="-20" />
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Grid>
            <Grid Margin="2,2,2,2" Grid.Column="2">
                <Image 
                    x:Name="RightCameraSmall"
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch"
                    MouseLeftButtonDown="Image_RightCameraMouseLeftButtonDown" 
                    Cursor="Hand"/>
                <TextBlock 
                    x:Name="RightCameraError"
                    Text="R Error" 
                    Height="85" 
                    FontSize="60" 
                    Foreground="Red" 
                    Visibility="Collapsed"
                    VerticalAlignment="Top" 
                    Margin="53,17,125,0" 
                    RenderTransformOrigin="0.476,0.504" >
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="-20" />
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Grid>
        </Grid>

        <!-- Wiersz 2 z innym podziałem -->
        <Grid Margin="0,2,0,0" Grid.Row="2">
            <!--    <Border BorderBrush="Blue" BorderThickness="1" Margin="0,0,0,-100"/> -->
            <Image 
                x:Name="MainCamera" 
                Margin="0,0,0,-100" 
                HorizontalAlignment="Stretch" 
                VerticalAlignment="Stretch"
                MouseLeftButtonDown="Image_CentralCameraTermovisionMouseLeftButtonDown" 
                Cursor="Hand"/>
        </Grid>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <Image Margin="5,5,5,5" Grid.Column="0" Source="Icons/KompasCopy.png" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"/>
            <Image Margin="5,5,5,5" Grid.Column="1" Source="Icons/SztucznyHoryzont.png" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"/>
            <Image Margin="5,5,5,5" Grid.Column="2" Source="Icons/KompasCopy.png" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"/>
            <Image Margin="5,5,5,5" Grid.Column="3" Source="Icons/SztucznyHoryzont.png" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"/>
            <Canvas x:Name="MainCanvasLeft" Background="LightGray" Grid.Column="4" >
                <Image x:Name="BackgroundImageLeft" Source="Icons/Siatka.png" Width="100" Height="100"/>
                <Canvas x:Name="CrosshairLeft" Width="20" Height="20" Margin="1,1,1,1">
                    <Line X1="10" Y1="0" X2="10" Y2="20" Stroke="Red" StrokeThickness="2" />
                    <Line X1="0" Y1="10" X2="20" Y2="10" Stroke="Red" StrokeThickness="2" />
                </Canvas>
            </Canvas>
            <Canvas x:Name="MainCanvasRight" Background="LightGray" Grid.Column="5" >
                <Image x:Name="BackgroundImageRight" Source="Icons/Siatka.png" Width="100" Height="100"/>
                <Canvas x:Name="CrosshairRight" Width="20" Height="20" Margin="1,1,1,1">
                    <Line X1="10" Y1="0" X2="10" Y2="20" Stroke="Red" StrokeThickness="2" />
                    <Line X1="0" Y1="10" X2="20" Y2="10" Stroke="Red" StrokeThickness="2" />
                </Canvas>
            </Canvas>

            <!--            <TextBlock x:Name="StatusLabelLeft" Grid.Column="6" VerticalAlignment="Top" HorizontalAlignment="Center" TextWrapping="Wrap" Text="Szukanie kontrolera..." TextAlignment="Center" FontSize="15" Foreground="Orange" Height="50" Width="163"/> -->
            <!--            <TextBlock x:Name="StatusLabelRight" Grid.Column="6" VerticalAlignment="Top" HorizontalAlignment="Center" TextWrapping="Wrap" Text="Szukanie kontrolera..." TextAlignment="Center" FontSize="15" Foreground="Orange" Height="50" Width="163" Margin="0,50,0,0"/> -->
            <TextBox x:Name="TextBoxToRead" Grid.Column="7" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="144" MaxLength="20" Margin="0,5,0,0"/>
            <TextBox x:Name="TextBoxToSend" Grid.Column="7" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="144" MaxLength="20" Margin="0,32,0,0" TextChanged="TextBoxToSend_TextChanged"/>
            <Button x:Name="SendButton" Grid.Column="7" Content="SEND" HorizontalAlignment="Center" Margin="0,64,0,0" VerticalAlignment="Top" Width="144" Height="26" Click="SendButton_Click"/>
            <Button x:Name="JoyStatusRight" Grid.Column="9" Content="Joy Right" HorizontalAlignment="Center" Margin="0,64,0,0" VerticalAlignment="Top" Width="80" Height="26"/>
            <Button x:Name="JoyStatusLeft" Grid.Column="9" Content="Joy Left" HorizontalAlignment="Center" Margin="0,13,0,0" VerticalAlignment="Top" Width="80" Height="26"/>
            <Button x:Name="ButtonStart" Grid.Column="10" FontSize="30" Content="Start" Click="ButtonStart_Click" Background="Green"/>
            <Button x:Name="Day_Night_Central_Status" Grid.Column="8" Content="Day/Night Central" HorizontalAlignment="Center" Margin="0,34,0,0" VerticalAlignment="Top" Width="126" Height="25" Background="Yellow" Click="Day_Night_Click_Central" />
            <Button x:Name="Day_Night_Left_Status" Grid.Column="8" Content="Day/Night Left" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="126" Height="25" Background="Yellow" Click="Day_Night_Click_Left"/>
            <Button x:Name="Day_Night_Right_Status" Grid.Column="8" Content="Day/Night Right" HorizontalAlignment="Center" Margin="0,64,0,0" VerticalAlignment="Top" Width="126" Height="25" Background="Yellow" Click="Day_Night_Click_Right"/>

        </Grid>

    </Grid>
</Window>
